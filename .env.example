# Copy this file to `.env` and fill in real keys from the Clerk dashboard.
#
# The bug reproduces regardless of whether the keys are valid — the
# auto-import bundler corruption fires at module-load time, before
# Clerk's middleware actually authenticates anything. But Nuxt's runtime
# config requires the keys to exist for `@clerk/nuxt`'s setup to be
# stable, so set them anyway.
#
# Keys are at https://dashboard.clerk.com → API Keys (any dev instance works).

NUXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me
NUXT_CLERK_SECRET_KEY=sk_test_replace_me
